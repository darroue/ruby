# Specify target ruby version
version="3.3.0"

packages_production="tzdata zip redis-server libvips"
commands_production="echo OK"

packages_development=""
commands_development="curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash && source /root/.nvm/nvm.sh && nvm install --lts"
